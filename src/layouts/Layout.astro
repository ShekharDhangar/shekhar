---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';
import ThemeToggle from '../components/ThemeToggle.astro';
import QuakeTerminal from '../components/QuakeTerminal.astro';
import { SOCIAL_LINKS, EMAIL_HREF } from '../lib/links';
import { PROFILE, KNOWS_ABOUT } from '../lib/profile';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Shekhar Dhangar — Software Engineer' } = Astro.props;
const path = Astro.url.pathname;

// schema.org Person — machine-readable identity for search engines and AI agents.
// Built from the same single-source constants the rest of the site uses.
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: PROFILE.name,
  url: Astro.site?.href,
  jobTitle: PROFILE.jobTitle,
  email: EMAIL_HREF.replace('mailto:', ''),
  description: PROFILE.summary,
  knowsAbout: KNOWS_ABOUT,
  sameAs: SOCIAL_LINKS.filter((l) => l.href.startsWith('http')).map((l) => l.href),
};
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={new URL(path, Astro.site).href} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personLd)} />
    <ClientRouter />
    <Font cssVariable="--font-source-code-pro" preload />
    <script is:inline>
      (function () {
        // Theme priority: explicit user override → OS preference → dark.
        function preferredTheme() {
          var saved = localStorage.getItem('theme');
          if (saved === 'dark' || saved === 'light') return saved;
          if (window.matchMedia('(prefers-color-scheme: light)').matches) return 'light';
          return 'dark';
        }
        window.__preferredTheme = preferredTheme;
        document.documentElement.setAttribute('data-theme', preferredTheme());
      })();
    </script>
  </head>
  <body>
    <QuakeTerminal />
    <header class="topbar">
      <div class="topbar-left">
        <a href="/" class={`topbar-name${path === '/' ? ' active' : ''}`}>/ shekhar</a>
        <a href="/blogs" class={path.startsWith('/blogs') ? 'active' : ''}>/ blogs</a>
        <a href="/learnings" class={path.startsWith('/learnings') ? 'active' : ''}>/ learnings</a>
      </div>
      <ThemeToggle />
    </header>

    <div class="page-wrap">
      <aside class="sidebar">
        <a href="/" class="sidebar-name">shekhar</a>
        <nav class="sidebar-nav">
          <a href="/blogs" class={path.startsWith('/blogs') ? 'active' : ''}>/blogs</a>
          <a href="/learnings" class={path.startsWith('/learnings') ? 'active' : ''}>/learnings</a>
        </nav>
      </aside>

      <div class="content-wrap">
        <main class="content">
          <ThemeToggle />
          <slot />
        </main>
      </div>
    </div>

    <script is:inline>
      (function () {
        // Bind once even though this inline script re-runs on view transitions.
        if (window.__themeBound) return;
        window.__themeBound = true;

        // Delegated so it keeps working after navigation swaps the buttons.
        document.addEventListener('click', function (e) {
          if (!e.target.closest('.theme-toggle')) return;
          var next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
        });

        // Follow the OS only while the user hasn't overridden.
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function () {
          if (localStorage.getItem('theme')) return;
          document.documentElement.setAttribute('data-theme', window.__preferredTheme());
        });

        // Re-apply after view-transition navigation, before the new page paints
        // (the swapped-in HTML resets data-theme to its SSR default).
        document.addEventListener('astro:after-swap', function () {
          document.documentElement.setAttribute('data-theme', window.__preferredTheme());
        });

        // Highlight the current nav link. Runs on first load and after every
        // view-transition navigation, so the active state stays in sync without
        // a full refresh.
        function updateActiveNav() {
          var path = location.pathname;
          document.querySelectorAll('.sidebar-nav a, .topbar-left a').forEach(function (a) {
            var href = a.getAttribute('href');
            var active = href === '/' ? path === '/' : path.startsWith(href);
            a.classList.toggle('active', active);
          });
        }
        // page-load covers the initial load; after-swap updates the highlight
        // before the new page paints, so it never lags behind navigation.
        document.addEventListener('astro:page-load', updateActiveNav);
        document.addEventListener('astro:after-swap', updateActiveNav);
      })();
    </script>

    <script is:inline>
      (function () {
        // Bind once; the handler re-runs on every navigation via astro:page-load.
        if (window.__copyBtnBound) return;
        window.__copyBtnBound = true;

        // Whether a block gets a button is decided at build time by the Shiki
        // `copy-attr` transformer (driven by the fence meta) and surfaced as
        // data-copy. Here we just honor it.
        function addCopyButtons() {
          document.querySelectorAll('pre.astro-code').forEach(function (pre) {
            if (pre.dataset.copyReady) return;
            pre.dataset.copyReady = '1';
            if (pre.getAttribute('data-copy') !== 'true') return;

            // Wrap so the button stays pinned while the <pre> scrolls horizontally.
            var wrap = document.createElement('div');
            wrap.className = 'code-block';
            pre.parentNode.insertBefore(wrap, pre);
            wrap.appendChild(pre);

            var btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'copy-btn';
            btn.textContent = 'Copy';
            btn.setAttribute('aria-label', 'Copy code to clipboard');
            btn.addEventListener('click', function () {
              var code = pre.querySelector('code');
              navigator.clipboard.writeText(code.innerText).then(function () {
                btn.textContent = 'Copied';
                btn.classList.add('copied');
                setTimeout(function () {
                  btn.textContent = 'Copy';
                  btn.classList.remove('copied');
                }, 1400);
              });
            });
            wrap.appendChild(btn);
          });
        }

        document.addEventListener('astro:page-load', addCopyButtons);
      })();
    </script>

    <script is:inline>
      (function () {
        if (window.__linkPreviewBound) return;
        window.__linkPreviewBound = true;

        // Hover previews are a desktop nicety — skip touch / coarse pointers.
        if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;

        var card, img, hideTimer;
        var cache = {}; // href -> screenshot URL, so re-hover never refetches

        function ensureCard() {
          if (card) return;
          card = document.createElement('div');
          card.className = 'link-preview-card';
          img = document.createElement('img');
          img.alt = '';
          card.appendChild(img);
          document.body.appendChild(card);
        }

        function screenshotURL(href) {
          // microlink returns the raw screenshot image via embed=screenshot.url.
          return 'https://api.microlink.io/?url=' + encodeURIComponent(href) +
            '&screenshot=true&meta=false&embed=screenshot.url';
        }

        function position(link) {
          var r = link.getBoundingClientRect();
          var w = card.offsetWidth || 320;
          var left = Math.min(Math.max(8, r.left + r.width / 2 - w / 2), window.innerWidth - w - 8);
          var top = r.top - card.offsetHeight - 10;
          if (top < 8) top = r.bottom + 10; // not enough room above → flip below
          card.style.left = left + 'px';
          card.style.top = top + 'px';
        }

        function show(link) {
          ensureCard();
          clearTimeout(hideTimer);
          var href = link.href;
          if (!cache[href]) cache[href] = screenshotURL(href); // lazy: first hover only
          if (img.src !== cache[href]) img.src = cache[href];
          requestAnimationFrame(function () {
            position(link);
            card.classList.add('visible');
          });
        }

        function hide() {
          if (!card) return;
          hideTimer = setTimeout(function () { card.classList.remove('visible'); }, 80);
        }

        function bindLinks() {
          document.querySelectorAll('a[data-preview]').forEach(function (link) {
            if (link.__previewBound) return;
            link.__previewBound = true;
            link.addEventListener('mouseenter', function () { show(link); });
            link.addEventListener('mouseleave', hide);
          });
        }

        document.addEventListener('astro:page-load', bindLinks);
      })();
    </script>
  </body>
</html>
