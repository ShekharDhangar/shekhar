---
import Layout from '../layouts/Layout.astro';
import { EMAIL_HREF, linkHref } from '../lib/links';
import GitHub from '../components/icons/GitHub.astro';
import Twitter from '../components/icons/Twitter.astro';
import LinkedIn from '../components/icons/LinkedIn.astro';
import Email from '../components/icons/Email.astro';

const contactIcons = [
  { slug: 'github',   icon: GitHub,   label: 'GitHub',      external: true },
  { slug: 'twitter',  icon: Twitter,  label: 'Twitter / X', external: true },
  { slug: 'linkedin', icon: LinkedIn, label: 'LinkedIn',    external: true },
  { slug: 'email',    icon: Email,    label: 'Email',       external: false },
].map((c) => ({ ...c, href: linkHref(c.slug) }));
---

<Layout title="Shekhar Dhangar" description="Shekhar Dhangar — software engineer working on distributed systems, backend infrastructure, and whatever's interesting enough to pull me in. Blogs and learnings from my public second brain.">
  <div class="section">
    <h2 class="section-heading">Hi!</h2>
    <hr class="section-divider" />
    <p>
      I'm Shekhar Dhangar, a Software Engineer. I work on distributed systems, backend
      infrastructure, and occasionally venture into whatever is interesting enough to pull me in.
    </p>
    <br />
    <p>
      This site is my public second brain — blogs when I have something to say, learnings when
      I'm figuring something out.
    </p>
  </div>

  <div class="section">
    <h2 class="section-heading">Contact</h2>
    <hr class="section-divider" />
    <p>
      Have something interesting to build? Drop me a <a href={EMAIL_HREF}>mail</a>. I'm open to conversations about hard engineering problems, new projects, or just trading ideas.
    </p>
    <div class="contact-icons-wrap">
      <hr class="section-divider" style="margin-bottom: 0" />
      <div class="contact-icons">
        {contactIcons.map(({ href, icon: Icon, label, external }) => (
          <a
            href={href}
            aria-label={label}
            class="contact-icon"
            target={external ? '_blank' : undefined}
            rel={external ? 'noopener noreferrer' : undefined}
          >
            <Icon />
          </a>
        ))}
      </div>
      <hr class="section-divider" style="margin-top: 0" />
    </div>
  </div>

</Layout>
